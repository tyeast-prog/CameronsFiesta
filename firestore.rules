rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Event & Menu Config ──────────────────────────────────────
    // Anyone can read; only authenticated admin can write
    match /config/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Side Dish Items ─────────────────────────────────────────
    // Anyone can read; admin can create/update/delete freely.
    // Unauthenticated users may update ONLY claimedCount (+1) and signups
    // (arrayUnion of one signup) — this supports the RSVP transaction.
    match /sideItems/{itemId} {
      allow read: if true;
      allow create, delete: if request.auth != null;
      allow update: if request.auth != null
        || (
          // Guest claiming a slot: only claimedCount & signups change
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['claimedCount', 'signups'])
          // claimedCount must increase by exactly 1 and not exceed needed
          && request.resource.data.claimedCount == resource.data.claimedCount + 1
          && request.resource.data.claimedCount <= resource.data.needed
        );
    }

    // ── RSVPs ────────────────────────────────────────────────────
    // Anyone can submit an RSVP; only authenticated admin can read/delete
    match /rsvps/{rsvpId} {
      allow create: if true;
      allow read, list, update, delete: if request.auth != null;
    }
  }
}
