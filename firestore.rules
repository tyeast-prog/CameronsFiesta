rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Event & Menu Config ──────────────────────────────────────
    // Anyone can read; only authenticated admin can write
    match /config/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Side Dish Items ─────────────────────────────────────────
    // Anyone can read; admin can create/update/delete freely.
    // Unauthenticated users may update ONLY claimedCount (+1) and signups
    // (arrayUnion of one signup) — this supports the RSVP transaction.
    match /sideItems/{itemId} {
      allow read: if true;
      allow create, delete: if request.auth != null;
      allow update: if request.auth != null
        || (
          // Guest claiming a slot — avoid diff().affectedKeys() which has a
          // Firebase bug with FieldValue.increment(n>1): phantom keys appear
          // and cause hasOnly() to return false. Instead, explicitly verify:

          // 1. claimedCount must increase and not exceed needed
          request.resource.data.claimedCount > resource.data.claimedCount
          && request.resource.data.claimedCount <= resource.data.needed

          // 2. Protected fields are unchanged
          && request.resource.data.name        == resource.data.name
          && request.resource.data.description == resource.data.description
          && request.resource.data.needed      == resource.data.needed
          && request.resource.data.unit        == resource.data.unit
          && request.resource.data.order       == resource.data.order

          // 3. signups can only grow, never shrink
          && request.resource.data.signups.size() >= resource.data.signups.size()
        );
    }

    // ── RSVPs ────────────────────────────────────────────────────
    // Anyone can submit an RSVP; only authenticated admin can read/delete
    match /rsvps/{rsvpId} {
      allow create: if true;
      allow read, list, update, delete: if request.auth != null;
    }
  }
}
